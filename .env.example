# Kinetics.CRM — Frontend Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env.local for local development overrides

# Backend API URL
# In development: leave blank (Vite proxy handles /api → localhost:3000)
# In production: set to your Render backend URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com/api
